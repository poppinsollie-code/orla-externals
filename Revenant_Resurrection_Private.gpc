detected_weapon = 6;
weapon_recoil_v = 14;
weapon_recoil_h = 2;
}
} else if(settings[S_GameProfile]==GAME_OVERWATCH) {
if(shot_interval <= 3) {
detected_weapon = 1;
weapon_recoil_v = 10;
weapon_recoil_h = 2;
} else if(shot_interval <= 6) {
detected_weapon = 2;
weapon_recoil_v = 14;
weapon_recoil_h = 3;
} else if(shot_interval <= 12) {
detected_weapon = 3;
weapon_recoil_v = 18;
weapon_recoil_h = 3;
} else {
detected_weapon = 4;
weapon_recoil_v = 8;
weapon_recoil_h = 1;
}
} else if(settings[S_GameProfile]==GAME_FINALS) {
if(shot_interval <= 2) {
detected_weapon = 1;
weapon_recoil_v = 32;
weapon_recoil_h = 6;
} else if(shot_interval <= 4) {
detected_weapon = 2;
weapon_recoil_v = 28;
weapon_recoil_h = 5;
} else if(shot_interval <= 7) {
detected_weapon = 3;
weapon_recoil_v = 24;
weapon_recoil_h = 4;
} else if(shot_interval <= 12) {
detected_weapon = 4;
weapon_recoil_v = 18;
weapon_recoil_h = 3;
} else {
detected_weapon = 5;
weapon_recoil_v = 10;
weapon_recoil_h = 2;
}
} else if(settings[S_GameProfile]==GAME_ARCRAIDERS) {
if(shot_interval <= 3) {
detected_weapon = 1;
weapon_recoil_v = 36;
weapon_recoil_h = 6;
} else if(shot_interval <= 5) {
detected_weapon = 2;
weapon_recoil_v = 30;
weapon_recoil_h = 5;
} else if(shot_interval <= 8) {
detected_weapon = 3;
weapon_recoil_v = 24;
weapon_recoil_h = 4;
} else if(shot_interval <= 15) {
detected_weapon = 4;
weapon_recoil_v = 16;
weapon_recoil_h = 3;
} else {
detected_weapon = 5;
weapon_recoil_v = 10;
weapon_recoil_h = 2;
}
} else if(settings[S_GameProfile]==GAME_TITANFALL) {
if(shot_interval <= 2) {
detected_weapon = 1;
weapon_recoil_v = 32;
weapon_recoil_h = 5;
} else if(shot_interval <= 4) {
detected_weapon = 2;
weapon_recoil_v = 28;
weapon_recoil_h = 4;
} else if(shot_interval <= 7) {
detected_weapon = 3;
weapon_recoil_v = 24;
weapon_recoil_h = 4;
} else if(shot_interval <= 12) {
detected_weapon = 4;
weapon_recoil_v = 18;
weapon_recoil_h = 3;
} else {
detected_weapon = 5;
weapon_recoil_v = 10;
weapon_recoil_h = 1;
}
} else {
if(shot_count <= 3) {
    weapon_recoil_v = (settings[S_Recoil] * 10);
    weapon_recoil_h = 0;
} else {
    weapon_recoil_v = (weapon_recoil_v * 7 + (settings[S_Recoil] * 10)) / 10;
}
}
}
function ApplyVMSpeed() {
    if(detected_platform==PLAT_PS5 || detected_platform==PLAT_XSX || detected_platform==PLAT_PC) {
        vm_tctrl(1);
        fps_divisor = 4;
    } else if(detected_platform==PLAT_PS4 || detected_platform==PLAT_XBONE || detected_platform==PLAT_XSS) {
        vm_tctrl(4);
        fps_divisor = 2;
    } else {
        vm_tctrl(10);
        fps_divisor = 1;
    }
}
