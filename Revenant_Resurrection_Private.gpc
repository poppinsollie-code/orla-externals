combo QuickEdit {
    set_val(PS4_CIRCLE, 100);
    set_val(PS4_CIRCLE, 0);
}
combo PeekRight {
    set_val(PS4_R3, 100);
    set_val(PS4_R3, 0);
}
combo PeekLeft {
    set_val(PS4_L3, 100);
    set_val(PS4_L3, 0);
}
combo RapidFireCombo {
    set_val(FIRE_BTN, 100);
    wait(GetSmartComboTiming(settings[S_RapidSpeed]));
    set_val(FIRE_BTN, 0);
    wait(GetSmartComboTiming(settings[S_RapidSpeed]));
}
combo QuickReloadCombo {
set_val(RELOAD_BTN, 100);wait(10);set_val(RELOAD_BTN, 0);wait(10);
}
combo BuildRapidCombo {
set_val(FIRE_BTN, 100);wait(2);set_val(FIRE_BTN, 0);wait(2);
}
combo TacSprintCombo {set_val(SPRINT_BTN, 100);temp1 = GetSmartComboTiming(40);wait(temp1);set_val(SPRINT_BTN, 0);temp1 = GetSmartComboTiming(40);wait(temp1);set_val(SPRINT_BTN, 100);temp1 = GetSmartComboTiming(40);wait(temp1);set_val(SPRINT_BTN, 0);}
combo BunnyHopCombo {set_val(JUMP_BTN, 100);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(JUMP_BTN, 0);temp1 = GetSmartComboTiming(175 - settings[S_HopRate]);wait(temp1);}
combo SlideCancelCombo {set_val(CROUCH_BTN, 100);temp1 = GetSmartComboTiming(80);wait(temp1);set_val(CROUCH_BTN, 0);temp1 = GetSmartComboTiming(80);wait(temp1);set_val(CROUCH_BTN, 100);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(CROUCH_BTN, 0);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(JUMP_BTN, 100);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(JUMP_BTN, 0);}
combo CrouchSpamCombo {set_val(CROUCH_BTN, 100);temp1 = GetSmartComboTiming(170 - settings[S_CrouchRate]);wait(temp1);set_val(CROUCH_BTN, 0);temp1 = GetSmartComboTiming(175 - settings[S_CrouchRate]);wait(temp1);}
combo DropShotCombo {set_val(CROUCH_BTN, 100);temp1 = GetSmartComboTiming(100);wait(temp1);set_val(CROUCH_BTN, 0);}
combo JumpShotCombo {set_val(JUMP_BTN, 100);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(JUMP_BTN, 0);}
combo QuickScopeCombo {set_val(FIRE_BTN, 100);temp1 = GetSmartComboTiming(80);wait(temp1);set_val(FIRE_BTN, 0);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(ADS_BTN, 0);}
combo TurboBuildCombo {set_val(FIRE_BTN, 100);temp1 = GetSmartComboTiming(20);wait(temp1);set_val(FIRE_BTN, 0);temp1 = GetSmartComboTiming(15);wait(temp1);}
combo FastEditCombo {set_val(FIRE_BTN, 100);temp1 = GetSmartComboTiming(30);wait(temp1);set_val(FIRE_BTN, 0);temp1 = GetSmartComboTiming(20);wait(temp1);}
combo FastLootCombo {set_val(PS4_SQUARE, 100);temp1 = GetSmartComboTiming(25);wait(temp1);set_val(PS4_SQUARE, 0);temp1 = GetSmartComboTiming(25);wait(temp1);}
combo ReloadCancelCombo {set_val(SWAP_BTN, 100);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(SWAP_BTN, 0);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(SWAP_BTN, 100);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(SWAP_BTN, 0);}
combo QuickKnifeCombo {set_val(MELEE_BTN, 100);temp1 = GetSmartComboTiming(80);wait(temp1);set_val(MELEE_BTN, 0);temp1 = GetSmartComboTiming(50);wait(temp1);set_val(FIRE_BTN, 100);temp1 = GetSmartComboTiming(30);wait(temp1);set_val(FIRE_BTN, 0);}
function GetPhysicalStrafeTime() {
    temp4 = game_strafe_timing - (settings[S_StrafeSpeed] - 20);
    if(temp4 < 10) temp4 = 10;
    if(temp4 > 80) temp4 = 80;
    return temp4;
}
combo PhysicalStrafeCombo {
    set_val(STICK_LX, 100);
    temp1 = GetPhysicalStrafeTime();
    wait(temp1);
    set_val(STICK_LX, -100);
    temp1 = GetPhysicalStrafeTime();
    wait(temp1);
    set_val(STICK_LX, 0);
}
