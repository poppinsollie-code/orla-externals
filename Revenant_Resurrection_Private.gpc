settings[S_AIAggression]=get_pvar(SPVAR_61, 50, 100, 100);
settings[S_PredictStr]=get_pvar(SPVAR_62, 50, 100, 100);
if(settings[S_AimPattern] > 5) settings[S_AimPattern] = 5;
if(settings[S_RecoilPattern] > 2) settings[S_RecoilPattern] = 2;
if(settings[S_SprintMode] > 2) settings[S_SprintMode] = 2;
