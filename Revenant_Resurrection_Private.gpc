function BlockButtons() {
set_val(PS4_CROSS, 0);set_val(PS4_CIRCLE, 0);set_val(PS4_SQUARE, 0);
set_val(PS4_TRIANGLE, 0);set_val(PS4_L1, 0);set_val(PS4_R1, 0);
set_val(PS4_L2, 0);set_val(PS4_R2, 0);set_val(PS4_L3, 0);
set_val(PS4_R3, 0);set_val(PS4_SHARE, 0);set_val(PS4_OPTIONS, 0);
set_val(PS4_TOUCH, 0);set_val(DPAD_UP, 0);set_val(DPAD_DOWN, 0);
set_val(DPAD_LEFT, 0);set_val(DPAD_RIGHT, 0);
set_val(STICK_LX, 0);set_val(STICK_LY, 0);
set_val(STICK_RX, 0);set_val(STICK_RY, 0);
}
init {
AutoDetectPlatform();
settings[S_Platform]=get_pvar(SPVAR_2,0,PLAT_AUTO,PLAT_AUTO);
menu_idx=get_pvar(SPVAR_64, 0, MENU_TOTAL - 1, 0);
