function ApplyWeaponAssists() {
    if(!settings[S_AimAssist] || !is_firing) {
        return;
    }
    if(weapon_type == 0 && shot_interval > 0) {
        if(shot_interval < 3) {
            weapon_type = 6;
        } else if(shot_interval < 6) {
            weapon_type = 3;
        } else if(shot_interval < 10) {
            weapon_type = 2;
        } else if(shot_interval < 15) {
            weapon_type = 1;
        } else if(shot_interval < 20) {
            weapon_type = 4;
        } else if(shot_interval > 25) {
            weapon_type = 0;
        } else {
            weapon_type = 5;
        }
    }
    if(weapon_type == 0) {
        prediction_active = 1;
        pull_strength = 450;
        snap_window = 450;
        snap_strength = 100;
    } else if(weapon_type == 1) {
        prediction_active = 1;
        pull_strength = 280;
    } else if(weapon_type == 2) {
        prediction_active = 1;
        pull_strength = 220;
    } else if(weapon_type == 3) {
        prediction_active = 1;
        pull_strength = 380;
    } else if(weapon_type == 4) {
        prediction_active = 1;
        pull_strength = 200;
    } else if(weapon_type == 5) {
        prediction_active = 1;
        pull_strength = 180;
    } else if(weapon_type == 6) {
        prediction_active = 1;
        pull_strength = 320;
        measured_recoil_v = (measured_recoil_v * 150) / 100;
    }
}
function Prediction() {
    if(!settings[S_AimAssist] || !settings[S_PredictEnable]) {
        prediction_active = 0;
        prediction_timer = 0;
        predicted_x = 0;
        predicted_y = 0;
        return;
    }

    temp1 = smooth_rx - rs_last_x;
    temp2 = smooth_ry - rs_last_y;

    rs_velocity_x = (temp1 * 90 + rs_velocity_x * 10) / 100;
    rs_velocity_y = (temp2 * 90 + rs_velocity_y * 10) / 100;
    rs_last_x = smooth_rx;
    rs_last_y = smooth_ry;

    temp3 = (rs_velocity_x - last_rs_vox);
    temp4 = (rs_velocity_y - last_rs_voy);
    last_rs_vox = rs_velocity_x;
    last_rs_voy = rs_velocity_y;
    temp1 = abs(rs_velocity_x) + abs(rs_velocity_y);

    if(base_magnitude < 30) prediction_threshold = 1;
    else if(base_magnitude < 60) prediction_threshold = 1;
    else prediction_threshold = 2;
    if(temp1 > prediction_threshold) {
        prediction_active = 1;
        prediction_timer = prediction_time;
        frames_tracking = frames_tracking + 1;
        if(frames_tracking > 60) frames_tracking = 60;
    } else if(prediction_timer > 0) {
        prediction_timer = prediction_timer - get_rtime();
        if(prediction_timer <= 0) {
            prediction_active = 0;
        }
    }
    if(prediction_active) {
        if(base_magnitude < 15) temp2 = 380;
        else if(base_magnitude < 30) temp2 = 480;
        else if(base_magnitude < 60) temp2 = 580;
        else if(base_magnitude < 85) temp2 = 680;
        else temp2 = 780;
        temp2 = (temp2 * settings[S_PredictStr]) / 100;
        if(settings[S_GameProfile] == GAME_BATTLEFIELD) temp2 = temp2 + 120;
        else if(settings[S_GameProfile] == GAME_DESTINY) temp2 = temp2 + 90;
        else if(settings[S_GameProfile] == GAME_APEX) temp2 = temp2 + 80;
        else if(settings[S_GameProfile] == GAME_COD) temp2 = temp2 + 60;
        if(temp2 > 32767) temp2 = 32767;
        temp1 = clamp(frames_tracking / 5, 1, 18);

        predicted_x = ((rs_velocity_x / 10) * (temp2 / 10) + (temp3 / 10) * (temp2 / 20)) * temp1 / 10;
        predicted_y = ((rs_velocity_y / 10) * (temp2 / 10) + (temp4 / 10) * (temp2 / 20)) * temp1 / 10;
        if(predicted_x > 32767) predicted_x = 32767;
        if(predicted_x < -32767) predicted_x = -32767;
        if(predicted_y > 32767) predicted_y = 32767;
        if(predicted_y < -32767) predicted_y = -32767;
        correction_x = correction_x + predicted_x;
        if(!head_locked || vertical_chase) {
            correction_y = correction_y + predicted_y;
        }
    } else {
        predicted_x = 0;
        predicted_y = 0;
    }
}
function LearnRecoil() {
    if(!is_firing || !settings[S_AdaptiveRec] || !settings[S_AILearning]) {
        return;
    }
    shots_fired_learning = shots_fired_learning + 1;
    if(shots_fired_learning % 5 == 0 && learning_samples < 20) {
        temp1 = abs(ry);
        temp2 = abs(rx);
        if(sample_index >= 20) sample_index = 0;
        recoil_sample_v[sample_index] = temp1;
        recoil_sample_h[sample_index] = temp2;
        sample_index = sample_index + 1;
        learning_samples = learning_samples + 1;
    }
    if(learning_samples >= 20 && shots_fired_learning > 100) {
        temp1 = 0;
        temp2 = 0;
        temp3 = 0;
        while(temp3 < 20) {
            temp1 = temp1 + recoil_sample_v[temp3];
            temp2 = temp2 + recoil_sample_h[temp3];
            temp3 = temp3 + 1;
        }
        measured_recoil_v = temp1 / 20;
        measured_recoil_h = temp2 / 20;
        if(detected_weapon > 0 && detected_weapon < 140) {
            temp1 = weapon_table_v[detected_weapon];
            temp2 = weapon_table_h[detected_weapon];
        } else {
            temp1 = weapon_recoil_v;
            temp2 = weapon_recoil_h;
        }
        if(shots_fired_learning < 50) {
            learning_confidence = (shots_fired_learning * 100) / 50;
        } else if(shots_fired_learning < 100) {
            learning_confidence = 100;
        } else {
            learning_confidence = 100;
        }
        if(settings[S_RecoilPattern] == 0) {
            learned_recoil_v = ((temp1 * (100 - learning_confidence)) + (measured_recoil_v * learning_confidence)) / 100;
            learned_recoil_h = ((temp2 * (100 - learning_confidence)) + (measured_recoil_h * learning_confidence)) / 100;
        } else if(settings[S_RecoilPattern] == 1) {
            learned_recoil_v = (measured_recoil_v * 90 + temp1 * 10) / 100;
            learned_recoil_h = (measured_recoil_h * 90 + temp2 * 10) / 100;
        } else if(settings[S_RecoilPattern] == 2) {
            learned_recoil_v = (measured_recoil_v * 80 + temp1 * 20) / 100;
            learned_recoil_h = (measured_recoil_h * 80 + temp2 * 20) / 100;
        } else {
            learned_recoil_v = measured_recoil_v;
            learned_recoil_h = measured_recoil_h;
        }
        if(learning_confidence > 20) {
            use_learned_value = 1;
            weapon_recoil_v = learned_recoil_v;
            weapon_recoil_h = learned_recoil_h;
        }
    }
}
function DetectWeapon2() {
    if(detected_game == GAME_FORTNITE) {
        if(shot_interval > 40) {
detected_weapon = WPN_FN_SCAR; weapon_recoil_v = 22; weapon_recoil_h = 3;
        } else if(shot_interval > 30) {
