function HarmonyAmplifier() {
    if(!settings[S_AimAssist]) {
        return;
    }
    friction_multiplier = 10000 + (game_friction_base - game_friction_base);
    pull_multiplier = 32767 + (game_pull_base - game_pull_base);
    prediction_multiplier = 32767 + (game_prediction - game_prediction);
    if(friction_multiplier > 10000) friction_multiplier = 10000;
    if(pull_multiplier > 32767) pull_multiplier = 32767;
    if(prediction_multiplier > 32767) prediction_multiplier = 32767;
    if(long_range_active) {
        friction_multiplier = (friction_multiplier * 130) / 100;
        pull_multiplier = 32767;
        prediction_multiplier = 32767;
    }
    prediction_multiplier = (prediction_multiplier * settings[S_PredictStr]) / 100;
    if(prediction_multiplier > 32767) prediction_multiplier = 32767;
}
function ExtremeLongRangeMagnetism() {
    if(!settings[S_AimAssist]) {
        long_range_active = 0;
        distance_magnetism = 100;
        return;
    }
    long_range_active = 1;
    distance_magnetism = 32000;
    sticky_lock_power = 32767;
    anti_drift_strength = 32767;
    if(shot_interval > 25 && bm > 40) {
        distance_magnetism = 32000;
        sticky_lock_power = 28000;
        anti_drift_strength = 20000;
    }
    breakaway_protection = 1;
    if(bm < 5) {
        center_pull_force = 32767;
        correction_x = correction_x - (smooth_rx * sticky_lock_power) / 1500;
        if(!head_locked) correction_y = correction_y - (smooth_ry * sticky_lock_power) / 1500;
    } else if(bm < 20) {
        center_pull_force = 32767;
        correction_x = correction_x - (smooth_rx * sticky_lock_power) / 2000;
        if(!head_locked) correction_y = correction_y - (smooth_ry * sticky_lock_power) / 2000;
    } else if(bm < 50) {
        center_pull_force = 30000;
        correction_x = correction_x - (smooth_rx * sticky_lock_power) / 3000;
        if(!head_locked) correction_y = correction_y - (smooth_ry * sticky_lock_power) / 3000;
    } else {
        center_pull_force = 24000;
    }
    if(abs(rx) > 0) {
        if(rx > 0) {
            correction_x = correction_x - center_pull_force;
        } else {
            correction_x = correction_x + center_pull_force;
        }
    }
    if(abs(ry) > 0 && !head_locked) {
        if(ry > 0) {
            correction_y = correction_y - center_pull_force;
        } else {
            correction_y = correction_y + center_pull_force;
        }
    }
    if(breakaway_protection) {
        temp2 = abs(rx) + abs(ry);
        if(temp2 < 90) {
            correction_x = correction_x - (rx * anti_drift_strength) / 8;
            if(!head_locked) correction_y = correction_y - (ry * anti_drift_strength) / 6;
        }
    }
    if(abs(velocity_x) > 1 || abs(velocity_y) > 1) {
        if((velocity_x > 0 && smooth_rx >= 0) || (velocity_x < 0 && smooth_rx <= 0)) {
            correction_x = correction_x + (velocity_x * (distance_magnetism / 300));
        }
        if(!head_locked) {
            if((velocity_y > 0 && smooth_ry >= 0) || (velocity_y < 0 && smooth_ry <= 0)) {
                correction_y = correction_y + (velocity_y * (distance_magnetism / 300));
            }
        }
    }
}
function UltraZeroDrift() {
    if(!settings[S_AimAssist]) {
        return;
    }
    if(bm < 10) {
        temp4 = 32767;
        if(temp4 > 32767) temp4 = 32767;
        if(abs(smooth_rx) > 0 && abs(smooth_rx) < 50) correction_x = correction_x - (smooth_rx * temp4);
        if(abs(smooth_ry) > 0 && abs(smooth_ry) < 50 && !head_locked) correction_y = correction_y - (smooth_ry * temp4);
    } else if(bm < 25) {
        temp4 = 28000;
        if(temp4 > 32767) temp4 = 32767;
        if(abs(smooth_rx) > 0 && abs(smooth_rx) < 50) correction_x = correction_x - (smooth_rx * temp4);
        if(abs(smooth_ry) > 0 && abs(smooth_ry) < 50 && !head_locked) correction_y = correction_y - (smooth_ry * temp4);
    } else {
        temp4 = 22000;
        if(temp4 > 32767) temp4 = 32767;
        if(abs(smooth_rx) > 0 && abs(smooth_rx) < 50) correction_x = correction_x - (smooth_rx * temp4);
        if(abs(smooth_ry) > 0 && abs(smooth_ry) < 50 && !head_locked) correction_y = correction_y - (smooth_ry * temp4);
    }
    if(is_firing) {
        if(bm < 15) {
            temp4 = 32767;
            if(temp4 > 32767) temp4 = 32767;
            if(abs(smooth_rx) > 0 && abs(smooth_rx) < 50) correction_x = correction_x - (smooth_rx * temp4);
            if(abs(smooth_ry) > 0 && abs(smooth_ry) < 50 && !head_locked) correction_y = correction_y - (smooth_ry * temp4);
        } else {
            temp4 = 28000;
            if(temp4 > 32767) temp4 = 32767;
            if(abs(smooth_rx) > 0 && abs(smooth_rx) < 50) correction_x = correction_x - (smooth_rx * temp4);
            if(abs(smooth_ry) > 0 && abs(smooth_ry) < 50 && !head_locked) correction_y = correction_y - (smooth_ry * temp4);
        }
    }
}
function GodModeAutoTrack() {
    if(!settings[S_AimAssist]) {
        return;
    }
    auto_track_timer = auto_track_timer + 1;
    center_lock_timer = center_lock_timer + 1;
    auto_track_target_x = 0 - smooth_rx;
    auto_track_target_y = 0 - smooth_ry;
    auto_track_center_x = 0 - smooth_rx;
    auto_track_center_y = 0 - smooth_ry;
    auto_track_lock_strength = 32767;
    auto_track_pull_strength = 32767;
    auto_track_smooth_x = auto_track_center_x;
    auto_track_smooth_y = auto_track_center_y;
    if(bm < 6) {
        temp1 = (auto_track_smooth_x / 10) * (auto_track_lock_strength / 200);
        temp2 = (auto_track_smooth_y / 10) * (auto_track_lock_strength / 200);
        if(temp1 > 32767) temp1 = 32767; if(temp1 < -32767) temp1 = -32767;
        if(temp2 > 32767) temp2 = 32767; if(temp2 < -32767) temp2 = -32767;
        correction_x = correction_x + temp1;
        if(!head_locked) correction_y = correction_y + temp2;
        correction_x = correction_x + (auto_track_target_x / 5) * (auto_track_pull_strength / 200);
        if(!head_locked) correction_y = correction_y + (auto_track_target_y / 5) * (auto_track_pull_strength / 200);
    } else if(bm < 20) {
        temp1 = (auto_track_smooth_x / 10) * (auto_track_lock_strength / 400);
        temp2 = (auto_track_smooth_y / 10) * (auto_track_lock_strength / 400);
        if(temp1 > 32767) temp1 = 32767; if(temp1 < -32767) temp1 = -32767;
        if(temp2 > 32767) temp2 = 32767; if(temp2 < -32767) temp2 = -32767;
        correction_x = correction_x + temp1;
        if(!head_locked) correction_y = correction_y + temp2;
        correction_x = correction_x + (auto_track_target_x / 5) * (auto_track_pull_strength / 400);
        if(!head_locked) correction_y = correction_y + (auto_track_target_y / 5) * (auto_track_pull_strength / 400);
    } else if(bm < 40) {
        temp1 = (auto_track_smooth_x / 10) * (auto_track_lock_strength / 800);
        temp2 = (auto_track_smooth_y / 10) * (auto_track_lock_strength / 800);
        if(temp1 > 32767) temp1 = 32767; if(temp1 < -32767) temp1 = -32767;
        if(temp2 > 32767) temp2 = 32767; if(temp2 < -32767) temp2 = -32767;
        correction_x = correction_x + temp1;
        if(!head_locked) correction_y = correction_y + temp2;
    }
    if(target_moving || is_firing) {
        if((velocity_x > 0 && smooth_rx >= 0) || (velocity_x < 0 && smooth_rx <= 0)) {
            temp1 = velocity_x * 12000;
            if(temp1 > 32767) temp1 = 32767; if(temp1 < -32767) temp1 = -32767;
            correction_x = correction_x + temp1;
        }
        if(!head_locked) {
            if((velocity_y > 0 && smooth_ry >= 0) || (velocity_y < 0 && smooth_ry <= 0)) {
                temp2 = velocity_y * 11000;
                if(temp2 > 32767) temp2 = 32767; if(temp2 < -32767) temp2 = -32767;
                correction_y = correction_y + temp2;
            }
        }
    }
    if(is_firing && bm < 55) {
        temp1 = auto_track_smooth_x * 6500;
        temp2 = auto_track_smooth_y * 5800;
        if(temp1 > 32767) temp1 = 32767; if(temp1 < -32767) temp1 = -32767;
        if(temp2 > 32767) temp2 = 32767; if(temp2 < -32767) temp2 = -32767;
        correction_x = correction_x + temp1;
        if(!head_locked) correction_y = correction_y + temp2;
    }
    if(target_moving && bm < 127) {
        correction_x = correction_x + (tracking_vel_x * 420);
        if(!head_locked) correction_y = correction_y + (tracking_vel_y * 380);
    }
    prediction_cycles = prediction_cycles + 1;
}
function AutonomousTargetFollow() {
    if(!settings[S_AimAssist]) {
        return;
    }
    atf_vel_x = smooth_rx;
    atf_vel_y = smooth_ry;
    temp1 = atf_vel_x * 1200;
    temp2 = atf_vel_y * 1100;
    if(temp1 > 32767) temp1 = 32767; if(temp1 < -32767) temp1 = -32767;
    if(temp2 > 32767) temp2 = 32767; if(temp2 < -32767) temp2 = -32767;
    correction_x = correction_x + temp1;
    if(!head_locked) correction_y = correction_y + temp2;
    if(target_moving) {
        correction_x = correction_x + (atf_vel_x * 900);
        if(!head_locked) correction_y = correction_y + (atf_vel_y * 850);
    }
    if(is_firing) {
        correction_x = correction_x + (atf_vel_x * 750);
        if(!head_locked) correction_y = correction_y + (atf_vel_y * 700);
    }
    if(target_moving && bm < 127) {
        correction_x = correction_x + (target_vel_x * 500);
        if(!head_locked) correction_y = correction_y + (target_vel_y * 480);
    }
}
function ClutchMode() {
    if(!settings[S_AimAssist] || !settings[S_PanicMode]) {
        return;
    }
    if(long_range_detected && is_ads && is_firing) {
        if(rx > 0) { correction_x = correction_x - 32767; }
        else if(rx < 0) { correction_x = correction_x + 32767; }
        if(ry > 0 && !head_locked) { correction_y = correction_y - 32767; }
        else if(ry < 0 && !head_locked) { correction_y = correction_y + 32767; }
        head_hold_strength = 32767;
        snap_strength = 100;
        snap_window = 450;
        return;
    }
    if(combat_intensity < 10 && engagement_counter < 1) {
        return;
    }
    if(combat_intensity > 50) {
        snap_window  = 450;
        snap_strength = 100;
        if(snap_window > 450) snap_window = 450;
    }
    if(bm < 15 && is_firing) {
        correction_x = correction_x - (smooth_rx * 16000);
        if(!head_locked) {
            correction_y = correction_y - (smooth_ry * 14000);
        }
    } else if(bm < 30 && (is_ads || is_firing)) {
        correction_x = correction_x - (smooth_rx * 10000);
        if(!head_locked) {
            correction_y = correction_y - (smooth_ry * 8500);
        }
    } else if(bm < 55 && (is_ads || is_firing)) {
        correction_x = correction_x - (smooth_rx * 6000);
        if(!head_locked) {
            correction_y = correction_y - (smooth_ry * 5000);
        }
    }
    if(target_moving) {
        correction_x = correction_x + (tracking_vel_x * 70);
        if(!head_locked) {
            correction_y = correction_y + (tracking_vel_y * 55);
        }
    }
    if(combat_intensity > 60 && is_ads && is_firing) {
        if(bm < 12) {
            correction_x = correction_x - (smooth_rx * 22000);
            if(!head_locked) {
                correction_y = correction_y - (smooth_ry * 19000);
            }
        } else if(bm < 35) {
            correction_x = correction_x - (smooth_rx * 14000);
            if(!head_locked) {
                correction_y = correction_y - (smooth_ry * 12000);
            }
        } else if(bm < 60) {
            correction_x = correction_x - (smooth_rx * 9000);
            if(!head_locked) {
                correction_y = correction_y - (smooth_ry * 7500);
            }
        }
    }
    if(head_locked && is_firing) {
        head_hold_strength = 32767;
    }
    if(target_moving && (abs(velocity_x) > 2 || abs(velocity_y) > 2)) {
        temp1 = (velocity_x * 150);
        if(temp1 > 32767) temp1 = 32767;
        if(temp1 < -32767) temp1 = -32767;
        temp2 = (velocity_y * 130);
        if(temp2 > 32767) temp2 = 32767;
        if(temp2 < -32767) temp2 = -32767;
        correction_x = correction_x + temp1;
        if(!head_locked) {
            correction_y = correction_y + temp2;
        }
    }
    if(engagement_counter > 200) {
        engagement_counter = 200;
    }
}

function ShotgunMagnetism() {
    if(!settings[S_AimAssist]) {
        return;
    }
    if(shot_interval <= 20 && !is_ads) {
        return;
    }
    if(shot_interval > 0 && shot_interval <= 20 && is_ads) {
        return;
    }
    if(bullet_event || (is_ads && !is_firing)) {
        correction_x = correction_x - (smooth_rx * 32767);
        correction_y = correction_y - (smooth_ry * 32767);
        head_locked = 1;
        head_hold_strength = 32767;
    head_locked = 1;
    }
    if(bm < 8) {
        correction_x = correction_x - (raw_smooth_rx * 32767);
        correction_y = correction_y - (raw_smooth_ry * 32767);
    } else if(bm < 20) {
        correction_x = correction_x - (raw_smooth_rx * 32767);
        correction_y = correction_y - (raw_smooth_ry * 32767);
    } else if(bm < 35) {
        correction_x = correction_x - (raw_smooth_rx * 28000);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 28000);
    } else if(bm < 55) {
        correction_x = correction_x - (raw_smooth_rx * 22000);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 22000);
    } else if(bm < 80) {
        correction_x = correction_x - (raw_smooth_rx * 16000);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 16000);
    } else if(bm < 110) {
        correction_x = correction_x - (raw_smooth_rx * 10000);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 10000);
    }
    if(target_moving && (abs(tracking_vel_x) > 1 || abs(tracking_vel_y) > 1)) {
        temp1 = (tracking_vel_x * 500);
        if(temp1 > 8000) temp1 = 8000;
        if(temp1 < -8000) temp1 = -8000;
        correction_x = correction_x + temp1;
        if(!head_locked) {
            temp2 = (tracking_vel_y * 480);
            if(temp2 > 7000) temp2 = 7000;
            if(temp2 < -7000) temp2 = -7000;
            correction_y = correction_y + temp2;
        }
    }
    if(head_locked && bm < 127) {
        head_hold_strength = 32767;
    }
}

function ZeroInputStickyLock() {
    if(!settings[S_AimAssist]) {
        return;
    }
    if(long_range_detected) {
        if(rx > 0) { correction_x = correction_x - 32767; }
        else if(rx < 0) { correction_x = correction_x + 32767; }
        if(ry > 0 && !head_locked) { correction_y = correction_y - 32767; }
        else if(ry < 0 && !head_locked) { correction_y = correction_y + 32767; }
        correction_x = correction_x - friction_multiplier;
        if(!head_locked) correction_y = correction_y - friction_multiplier;
        return;
    }
    if(bm < 5) {
        correction_x = correction_x - (raw_smooth_rx * 32767);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 32767);
    } else if(bm < 8) {
        correction_x = correction_x - (raw_smooth_rx * 28000);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 28000);
    } else if(bm < 14) {
        correction_x = correction_x - (raw_smooth_rx * 22000);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 22000);
    } else if(bm < 20) {
        correction_x = correction_x - (raw_smooth_rx * 16000);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 16000);
    }
    if(bm < 14) {
        if(abs(raw_smooth_rx) > 1) {
            if(raw_smooth_rx > 0) {
                correction_x = correction_x - friction_multiplier;
            } else {
                correction_x = correction_x + friction_multiplier;
            }
        }
        if(abs(raw_smooth_ry) > 1 && !head_locked) {
            if(raw_smooth_ry > 0) {
                correction_y = correction_y - friction_multiplier;
            } else {
                correction_y = correction_y + friction_multiplier;
            }
        }
    }
    if(bm < 50) {
        correction_x = correction_x - (raw_smooth_rx * 22);
        if(!head_locked) correction_y = correction_y - (raw_smooth_ry * 22);
    }
}
function InsertCharacter(value) {
putc_oled(menu_buf, value); menu_buf = menu_buf + 1;
}
function _in(value) {
if(value < 0) { InsertCharacter(45); value = abs(value); }
temp1 = value; temp2 = 0;
while(temp1) { temp1 = temp1 / 10; temp2 = temp2 + 1; }
if(temp2 == 0) temp2 = 1;
temp3 = 0;
while(temp3 < temp2) {
    temp1 = (value % 10) + 48; value = value / 10;
    putc_oled(menu_buf + temp2 - 1 - temp3, temp1);
    temp3 = temp3 + 1;
}
menu_buf = menu_buf + temp2;
}
function _is(str) {
while(dint8(str)) { InsertCharacter(dint8(str)); str = str + 1; }
}
function UpdateLEDs() {
    if(menu_open) {
        blink_timer = blink_timer + frame_time;
        if(blink_timer >= 250) {
            blink_timer = 0;
            blink_state = !blink_state;
        }
        if(blink_state) {
            set_led(LED_1, 3);
            set_led(LED_2, 3);
            set_led(LED_3, 3);
            set_led(LED_4, 3);
        } else {
            set_led(LED_1, 0);
            set_led(LED_2, 0);
            set_led(LED_3, 0);
            set_led(LED_4, 0);
        }
        return;
    }
    if(settings[S_LEDMode] == 0) {
        set_led(LED_1, 0);
        set_led(LED_2, 0);
        set_led(LED_3, 0);
        set_led(LED_4, 0);
        return;
    }
    temp1 = (settings[S_LEDBright] * 3) / 100;
    if(settings[S_LEDMode] == 1) {
        set_led(LED_1, temp1);
        set_led(LED_2, temp1);
        set_led(LED_3, temp1);
        set_led(LED_4, temp1);
    } else if(settings[S_LEDMode] == 2) {
        led_timer = led_timer + frame_time;
        if(led_timer >= 20) {
            led_timer = 0;
            if(led_pulse_dir == 0) {
                led_brightness = led_brightness + 1;
                if(led_brightness >= temp1) {
                    led_brightness = temp1;
                    led_pulse_dir = 1;
                }
            } else {
                led_brightness = led_brightness - 1;
                if(led_brightness <= 0) {
                    led_brightness = 0;
                    led_pulse_dir = 0;
                }
            }
        }
        set_led(LED_1, led_brightness);
        set_led(LED_2, led_brightness);
        set_led(LED_3, led_brightness);
        set_led(LED_4, led_brightness);
    } else if(settings[S_LEDMode] == 3) {
        led_timer = led_timer + frame_time;
        if(led_timer >= 50) {
            led_timer = 0;
            led_color_index = led_color_index + 1;
            if(led_color_index > 360) led_color_index = 0;
        }
        if(led_color_index < 60) {
            temp2 = (led_color_index * temp1) / 60;
            set_led(LED_1, temp1);
            set_led(LED_2, temp2);
            set_led(LED_3, 0);
        } else if(led_color_index < 120) {
            temp2 = ((120 - led_color_index) * temp1) / 60;
            set_led(LED_1, temp2);
            set_led(LED_2, temp1);
            set_led(LED_3, 0);
        } else if(led_color_index < 180) {
            temp2 = ((led_color_index - 120) * temp1) / 60;
            set_led(LED_1, 0);
            set_led(LED_2, temp1);
            set_led(LED_3, temp2);
        } else if(led_color_index < 240) {
            temp2 = ((240 - led_color_index) * temp1) / 60;
            set_led(LED_1, 0);
            set_led(LED_2, temp2);
            set_led(LED_3, temp1);
        } else if(led_color_index < 300) {
            temp2 = ((led_color_index - 240) * temp1) / 60;
            set_led(LED_1, temp2);
            set_led(LED_2, 0);
            set_led(LED_3, temp1);
        } else {
            temp2 = ((360 - led_color_index) * temp1) / 60;
            set_led(LED_1, temp1);
            set_led(LED_2, 0);
            set_led(LED_3, temp2);
        }
        set_led(LED_4, 0);
    }
    if(settings[S_AdvancedLED]) {
        if(is_ads) set_led(LED_4, temp1);
        if(is_firing) set_led(LED_1, temp1);
        if(head_locked) set_led(LED_2, temp1);
        if(target_moving && !is_ads && !is_firing) set_led(LED_3, temp1 / 2);
    }
}
function ResetAdaptiveState() {
    detect_candidate = 0;
    detect_conf = 0;
    detect_intensity = 0;
    detect_lock_timer = 0;
    prediction_active = 0;
    long_range_frames = 0;
    long_range_detected = 0;
    recoil_learn_accum_v = 0;
    recoil_learn_accum_h = 0;
    recoil_learn_frames = 0;
    direct_recoil_y = 0;
    direct_recoil_x = 0;
    prediction_timer = 0;
    frames_tracking = 0;
    sample_index = 0;
    learning_samples = 0;
    learning_confidence = 0;
    shots_fired_learning = 0;
    measured_recoil_v = 0;
    measured_recoil_h = 0;
    learned_recoil_v = 0;
    learned_recoil_h = 0;
    learned_boost_v = 0;
    learned_boost_h = 0;
    head_locked = 0;
    snap_phase = 0;
    snap_phase_timer = 0;
    target_vel_x = 0;
    target_vel_y = 0;
    target_pos_x = 0;
    target_pos_y = 0;
    tracking_vel_x = 0;
    tracking_vel_y = 0;
    wall_track_active = 0;
    wall_track_strength = 0;
    target_lost_timer = 0;
    hits = 0;
    shots = 0;
    player_skill = 0;
    correction_x = 0;
    correction_y = 0;
    smooth_correction_x = 0;
    smooth_correction_y = 0;
    prev_correction_x = 0;
    prev_correction_y = 0;
}
function ApplyMenuRuntimeTuning() {
    temp1 = settings[S_ResponseL];
    if(temp1 != 100) {
        lx = (lx * temp1) / 100;
        ly = (ly * temp1) / 100;
    }
    temp1 = settings[S_ResponseR];
    if(is_ads) {
        if(weapon_type == 6 || shot_interval > 25) {
            temp2 = 100 + (settings[S_ScopeSens] - 85);
        } else {
            temp2 = 100 + (settings[S_ADSSens] - 95);
        }
    } else {
        temp2 = 100 + (settings[S_HipSens] - 100);
    }
    temp1 = (temp1 * temp2) / 100;
    temp1 = temp1 + ((settings[S_AimSpeed] - 20) * 2);
    if(settings[S_ProfileNum] == 1) temp1 = (temp1 * 104) / 100;
    else if(settings[S_ProfileNum] == 2) temp1 = (temp1 * 108) / 100;
    else if(settings[S_ProfileNum] == 3) temp1 = (temp1 * 96) / 100;
    blend_x = (blend_x * temp1) / 100;
    blend_y = (blend_y * temp1) / 100;
    if(settings[S_GyroEnable] && is_ads) {
        temp3 = settings[S_GyroSens] - 50;
        if(abs(blend_x) < 35) blend_x = blend_x + (smooth_x * temp3) / 100;
        if(abs(blend_y) < 35) blend_y = blend_y + (smooth_y * temp3) / 100;
    }
}
function SetMenuInfo() {
si = _menuOrder[menu_idx];
menu_type = _menuData[si][2]; menu_setting = settings[si];
DrawMenuScreen();
return;
}
function AdjustValue(dir) {
si = _menuOrder[menu_idx];
if(_menuData[si][2]==0) {
settings[si]=!settings[si];
} else if(si==S_Platform) {
settings[si]=settings[si] + dir;
if(settings[si]>PLAT_AUTO) settings[si]=0;
if(settings[si]<0) settings[si]=PLAT_AUTO;
RefreshPlatformConfig();
ApplyVMSpeed();
} else if(si==S_GameProfile) {
settings[si]=settings[si] + dir;
if(settings[si]>_menuData[si][1]) settings[si]=0;
if(settings[si]<0) settings[si]=_menuData[si][1];
ApplyGameProfile();
} else if(si==S_LootButton||si==S_AimPattern||si==S_RecoilPattern||si==S_SprintMode||si==S_SensCurve||si==S_LEDMode||si==S_ProfileNum) {
settings[si]=settings[si] + dir;
if(settings[si]>_menuData[si][1]) settings[si]=0;
if(settings[si]<0) settings[si]=_menuData[si][1];
} else {
settings[si]=settings[si] + dir;
if(settings[si]>_menuData[si][1]) settings[si]=_menuData[si][1];
if(settings[si]<_menuData[si][0]) settings[si]=_menuData[si][0];
}
}
function DrawMenuScreen() {
cls_oled(0);
rect_oled(0, 0, 128, 64, 0, 1);
line_oled(0, 20, 127, 20, 1, 1);
menu_buf = 1;
_is(addr(_menuNames[si]));
puts_oled(5, 5, OLED_FONT_SMALL, menu_buf - 1, OLED_WHITE);
menu_buf = 1;
if(si == S_AimPattern) { _is(addr(_aimPatternText[menu_setting]));
} else if(si == S_RecoilPattern) { _is(addr(_recoilPatternText[menu_setting]));
} else if(si == S_SprintMode) { _is(addr(_sprintModeText[menu_setting]));
} else if(si == S_SensCurve) { _is(addr(_sensCurveText[menu_setting]));
} else if(si == S_LEDMode) { _is(addr(_ledModeText[menu_setting]));
} else if(si == S_ProfileNum) { _is(addr(_profileText[menu_setting]));
} else if(si == S_GameProfile) { _is(addr(_gameProfileText[menu_setting]));
} else if(si == S_Platform) { _is(addr(_platformText[menu_setting]));
} else if(si == S_LootButton) { _is(addr(_lootButtonText[menu_setting]));
} else if(menu_type == 0) { _is(addr(_toggle[menu_setting]));
} else { _in(menu_setting); }
puts_oled(10, 35, OLED_FONT_MEDIUM, menu_buf - 1, OLED_WHITE);
return;
}
