        } else if(shot_interval > 15) {
detected_weapon = WPN_ARC_DEFENDER; weapon_recoil_v = 30; weapon_recoil_h = 4;
        } else {
detected_weapon = WPN_ARC_RAIDER; weapon_recoil_v = 25; weapon_recoil_h = 3;
        }
    }
    if(detected_weapon > 0 && detected_weapon < 140) {
        weapon_recoil_v = weapon_table_v[detected_weapon];
        weapon_recoil_h = weapon_table_h[detected_weapon];
        if(weapon_recoil_v > 25) {
            weapon_type = 1;
        } else if(weapon_recoil_v > 18) {
            weapon_type = 2;
        } else if(weapon_recoil_v > 12) {
            weapon_type = 3;
        } else {
            weapon_type = 4;
        }
        if(detected_weapon == WPN_FN_SCAR)                  spread_comp = 75;
        else if(detected_weapon == WPN_FN_AUG)              spread_comp = 65;
        else if(detected_weapon == WPN_FN_BURST)            spread_comp = 50;
        else if(detected_weapon == WPN_FN_SMG)              spread_comp = 90;
        else if(detected_weapon == WPN_FN_TAC)              spread_comp = 92;
        else if(detected_weapon == WPN_FN_HEAVY_SNIPER)     spread_comp = 0;
        else if(detected_weapon == WPN_FN_PUMP_SHOTGUN)     spread_comp = 100;
        else if(detected_weapon == WPN_FN_TACTICAL_SHOTGUN) spread_comp = 95;
        else if(detected_weapon == WPN_COD_AK47)            spread_comp = 55;
        else if(detected_weapon == WPN_COD_M4A1)            spread_comp = 40;
        else if(detected_weapon == WPN_COD_KILO)            spread_comp = 35;
        else if(detected_weapon == WPN_COD_MP5)             spread_comp = 65;
        else if(detected_weapon == WPN_COD_MP7)             spread_comp = 70;
        else if(detected_weapon == WPN_COD_M13)             spread_comp = 38;
        else if(detected_weapon == WPN_COD_GRAU)            spread_comp = 32;
        else if(detected_weapon == WPN_COD_FENNEC)          spread_comp = 80;
        else if(detected_weapon == WPN_COD_C58)             spread_comp = 45;
        else if(detected_weapon == WPN_APEX_FLATLINE)       spread_comp = 30;
        else if(detected_weapon == WPN_APEX_R301)           spread_comp = 25;
        else if(detected_weapon == WPN_APEX_VOLT)           spread_comp = 20;
        else if(detected_weapon == WPN_APEX_R99)            spread_comp = 45;
        else if(detected_weapon == WPN_APEX_CAR)            spread_comp = 48;
        else if(detected_weapon == WPN_APEX_ALTERNATOR)     spread_comp = 50;
        else if(detected_weapon == WPN_APEX_RE45)           spread_comp = 55;
        else if(detected_weapon == WPN_APEX_P2020)          spread_comp = 40;
        else if(detected_weapon == WPN_BF_SCAR)             spread_comp = 55;
        else if(detected_weapon == WPN_BF_M416)             spread_comp = 45;
        else if(detected_weapon == WPN_BF_AK5C)             spread_comp = 50;
        else if(detected_weapon == WPN_BF_ACR)              spread_comp = 35;
        else if(detected_weapon == WPN_BF_SVD)              spread_comp = 5;
        else if(detected_weapon == WPN_BF_M60)              spread_comp = 75;
        else if(detected_weapon == WPN_BF_AEK)              spread_comp = 45;
        else if(detected_weapon == WPN_R6_L85A2)            spread_comp = 5;
        else if(detected_weapon == WPN_R6_AR33)             spread_comp = 8;
        else if(detected_weapon == WPN_R6_9X19VSN)          spread_comp = 10;
        else if(detected_weapon == WPN_R6_C8SFW)            spread_comp = 6;
        else if(detected_weapon == WPN_R6_F2)               spread_comp = 5;
        else if(detected_weapon == WPN_R6_AK12)             spread_comp = 7;
        else if(detected_weapon == WPN_PUBG_AKM)            spread_comp = 60;
        else if(detected_weapon == WPN_PUBG_SCAR)           spread_comp = 55;
        else if(detected_weapon == WPN_PUBG_M416)           spread_comp = 50;
        else if(detected_weapon == WPN_PUBG_UMP)            spread_comp = 65;
        else if(detected_weapon == WPN_PUBG_VECTOR)         spread_comp = 78;
        else if(detected_weapon == WPN_XDEF_M4)             spread_comp = 38;
        else if(detected_weapon == WPN_XDEF_AK74)           spread_comp = 55;
        else if(detected_weapon == WPN_XDEF_VECTOR)         spread_comp = 75;
        else if(detected_weapon == WPN_XDEF_MP5)            spread_comp = 62;
        else if(detected_weapon == WPN_XDEF_SCAR)           spread_comp = 50;
        else if(detected_weapon == WPN_FINALS_AK)           spread_comp = 60;
        else if(detected_weapon == WPN_FINALS_M4)           spread_comp = 45;
        else if(detected_weapon == WPN_FINALS_SHOTGUN)      spread_comp = 95;
        else if(detected_weapon == WPN_FINALS_SMG)          spread_comp = 82;
        else if(detected_weapon == WPN_FINALS_SNIPER)       spread_comp = 0;
        else if(detected_weapon == WPN_ARC_RAIDER)          spread_comp = 45;
        else if(detected_weapon == WPN_ARC_DEFENDER)        spread_comp = 55;
        else if(detected_weapon == WPN_ARC_SNIPER)          spread_comp = 0;
        else if(detected_weapon == WPN_ARC_MACHINE)         spread_comp = 70;
        else if(detected_weapon == WPN_ARC_SHOTGUN)         spread_comp = 98;
        else                                                 spread_comp = 100;
        if(detected_game == GAME_HALO)      spread_comp = spread_comp / 4;
        if(detected_game == GAME_DESTINY)   spread_comp = spread_comp / 3;
        if(detected_game == GAME_OVERWATCH) spread_comp = spread_comp / 5;
        if(use_learned_value && learning_confidence > 20) {
            weapon_recoil_v = learned_recoil_v;
            weapon_recoil_h = learned_recoil_h;
        }
    } else {
        DetectWeapon();
        weapon_type = 2;
        if(detected_weapon == 0) {
            if(detected_game == GAME_FORTNITE) {
                weapon_recoil_v = 18;
                weapon_recoil_h = 3;
            } else if(detected_game == GAME_COD) {
                weapon_recoil_v = 60;
                weapon_recoil_h = 12;
            } else if(detected_game == GAME_APEX) {
                weapon_recoil_v = 28;
                weapon_recoil_h = 7;
            } else {
                weapon_recoil_v = 22;
                weapon_recoil_h = 4;
            }
        }
        if(use_learned_value && learning_confidence > 20) {
            weapon_recoil_v = learned_recoil_v;
            weapon_recoil_h = learned_recoil_h;
        }
    }
    if(!weapon_locked && detected_weapon > 0) {
        weapon_locked = 1;
        base_recoil_v = weapon_recoil_v;
        base_recoil_h = weapon_recoil_h;
        learned_boost_v = 0;
        learned_boost_h = 0;
    }
    weapon_recoil_v = (weapon_recoil_v * settings[S_RecoilVert] * 100) / 1600;
    if(settings[S_RecoilHoriz] > 0) {
        weapon_recoil_h = (weapon_recoil_h * settings[S_RecoilHoriz] * 100) / 2000;
    } else {
        weapon_recoil_h = 0;
    }
}
function GetSmartComboTiming(int base_timing) {
    return base_timing + (get_rtime() % 5);
}
function AutoDetectGame() {
    if(settings[S_GameProfile] != GAME_AUTO) {
        detected_game = settings[S_GameProfile];
        return;
    }
    if(fn_build_mode || fn_edit_mode) {
        detected_game = GAME_FORTNITE;
        detect_candidate = GAME_FORTNITE;
        detect_conf = 5;
        detect_lock_timer = 120;
        return;
    }
    if(is_sliding || tac_held) {
        detected_game = GAME_COD;
        detect_candidate = GAME_COD;
        detect_conf = 5;
        detect_lock_timer = 60;
        return;
    }
    if(detect_lock_timer > 0) {
        detect_lock_timer = detect_lock_timer - 1;
        return;
    }
    if(engagement_counter < 8) {
        return;
    }
    temp1 = 0;
    if(weapon_recoil_v == 0 && engagement_counter > 10) {
        temp1 = GAME_HALO;
    } else if(weapon_recoil_v > 40 && weapon_type_detected == 2
              && detect_intensity < 40 && avg_engagement_time < 70) {
        temp1 = GAME_R6SIEGE;
    } else if(weapon_recoil_v > 32 && weapon_type_detected == 1
              && avg_engagement_time > 80) {
        temp1 = GAME_PUBG;
    } else if(rapid_movement && direction_change > 8
              && weapon_recoil_v < 23 && weapon_type_detected == 3) {
        temp1 = GAME_OVERWATCH;
    } else if(weapon_recoil_v > 18 && rapid_movement
              && !is_sliding && !tac_held && direction_change > 4) {
        temp1 = GAME_APEX;
    } else if(weapon_type_detected == 3 && detect_intensity > 50
              && weapon_recoil_v < 38 && avg_engagement_time > 100) {
        temp1 = GAME_DESTINY;
    } else if(weapon_recoil_v > 24 && weapon_type_detected == 2
              && !is_sliding && !tac_held && direction_change < 6
              && detect_intensity > 20 && detect_intensity < 75) {
        temp1 = GAME_XDEFIANT;
    } else if(weapon_recoil_v < 26 && weapon_recoil_v > 0
              && !rapid_movement && detect_intensity < 55
              && avg_engagement_time < 90) {
        temp1 = GAME_FORTNITE;
    } else if(weapon_recoil_v < 32 && !rapid_movement
              && detect_intensity < 40 && avg_engagement_time > 60) {
        temp1 = GAME_BATTLEFIELD;
    } else if(weapon_recoil_v > 14 && weapon_recoil_v < 36
              && weapon_type_detected == 2 && detect_intensity > 30
              && direction_change > 2 && direction_change < 8) {
        temp1 = GAME_FINALS;
    } else if(weapon_recoil_v > 14 && weapon_recoil_v < 31
              && !rapid_movement && detect_intensity < 45
              && engagement_counter > 20) {
        temp1 = GAME_ARCRAIDERS;
    } else {
        temp1 = GAME_COD;
    }
    if(temp1 == detect_candidate) {
        detect_conf = detect_conf + 1;
        if(detect_conf > 5) detect_conf = 5;
    } else {
        detect_candidate = temp1;
        detect_conf = 1;
    }
    if(detect_conf >= 4) {
        detected_game = detect_candidate;
        detect_lock_timer = 90;
    }
}
function AutoAdapt() {
    adapt_game_timer = adapt_game_timer + 1;
    if(adapt_game_timer >= 30) { adapt_game_timer = 0; AutoDetectGame(); }
    if(settings[S_GameProfile] == GAME_AUTO && detected_game != prev_detected_game) {
        prev_detected_game = detected_game;
        prev_profile = -1;
        settings[S_GameProfile] = detected_game;
        ApplyGameProfile();
        settings[S_GameProfile] = GAME_AUTO;
        if(game_strafe_mult == 0) game_strafe_mult = 75;
        if(game_strafe_timing == 0) game_strafe_timing = 28;
        prev_profile = GAME_AUTO;
        detect_conf = 0;
        detect_lock_timer = 0;
        detect_intensity = 0;
        engagement_counter = 0;
        combat_intensity = 0;
        weapon_type_detected = 0;
        avg_engagement_time = 0;
        engage_timer = 0;
    }
    if(!settings[S_AimAssist]) {
        auto_mode = 0;
        return;
    }
    auto_mode = 1;
    if(detected_game == GAME_FORTNITE) {
        if(settings[S_BuildAssist] || settings[S_EditAssist]) {
            detected_mode = MODE_FN_BUILD;
        } else {
            detected_mode = MODE_FN_ZEROBUILD;
        }
        if(detect_intensity < 10 && engagement_counter < 5) {
            detected_mode = MODE_FN_CREATIVE;
        }
    } else if(detected_game == GAME_COD) {
        if(avg_engagement_time > 300) {
            detected_mode = MODE_COD_WARZONE;
        } else if(detect_intensity > 50) {
            detected_mode = MODE_COD_MP;
        } else if(detect_intensity < 25) {
            detected_mode = MODE_COD_TACTICAL;
        } else {
            detected_mode = MODE_COD_MP;
        }
    } else if(detected_game == GAME_APEX) {
        if(detect_intensity > 70) {
            detected_mode = MODE_APEX_CONTROL;
        } else if(engagement_counter > 10 && avg_engagement_time < 200) {
            detected_mode = MODE_APEX_ARENAS;
        } else {
            detected_mode = MODE_APEX_BR;
        }
    }
    if(is_firing || is_ads) {
        if(is_ads) {
            ads_duration = ads_duration + get_rtime();
        } else {
            ads_duration = 0;
        }
        combat_intensity = combat_intensity + 1;
        if(combat_intensity > 100) combat_intensity = 100;
    }
    temp1 = abs(rs_velocity_x) + abs(rs_velocity_y);
    if(temp1 > 20) {
        rapid_movement = 1;
        detected_situation = 2;
    } else if(temp1 > 5 && base_magnitude > 3) {
        rapid_movement = 0;        detected_situation = 1;
    } else if(base_magnitude < 3) {
        detected_situation = 3;
    }
    if(is_firing) {
        shot_frame_timer = shot_frame_timer + 1;
        if(shot_frame_timer > 20) {
            shot_count = shot_count + 1;
            shot_interval = shot_frame_timer;
            if(shot_interval > 8 && shot_interval < 15) {
                if(shot_count % 3 == 1) {
                    correction_reset = 1;
                }
            }
            shot_frame_timer = 0;
            engagement_counter = engagement_counter + 1;
            if(shot_interval > 50) {
                weapon_type_detected = 1;
            } else if(shot_interval > 15) {
                weapon_type_detected = 2;
            } else {
                weapon_type_detected = 3;
            }
            DetectWeapon2();
        }
    } else {
        shot_frame_timer = 0;
        if(weapon_locked) {
            weapon_locked = 0;
            learned_boost_v = 0;
            learned_boost_h = 0;
            recoil_learn_accum_v = 0;
            recoil_learn_accum_h = 0;
            recoil_learn_frames = 0;
        }
    }
    if(detected_mode == MODE_FN_BUILD) {
        if(detected_situation == 1) {
            prediction_active = 1;
            prediction_threshold = 1;
            prediction_time = 1600;
        } else if(detected_situation == 2) {
            prediction_active = 1;
            prediction_threshold = 1;
        } else if(detected_situation == 3) {
            prediction_active = 0;
        }
    } else if(detected_mode == MODE_FN_ZEROBUILD) {
        if(detected_situation == 1) {
            prediction_active = 1;
            prediction_threshold = 1;
            prediction_time = 1600;
        } else if(detected_situation == 2) {
            prediction_active = 1;
            prediction_threshold = 7;
        } else if(detected_situation == 3) {
            prediction_active = 0;
        }
    } else if(detected_mode == MODE_FN_CREATIVE) {
        if(detected_situation == 1) {
            prediction_active = 1;
            prediction_threshold = 6;
        } else {
            prediction_active = 1;
            prediction_threshold = 1;
        }
    } else if(detected_mode == MODE_COD_WARZONE) {
        if(detected_situation == 1) {
            prediction_active = 1;
            prediction_threshold = 2;
            prediction_time = 1600;
        } else if(detected_situation == 2) {
            prediction_active = 1;
            prediction_threshold = 1;
        } else if(detected_situation == 3) {
            prediction_active = 0;
        }
        if(settings[S_RecoilControl] && settings[S_Recoil] == 0) { LearnRecoil(); }
    } else if(detected_mode == MODE_COD_MP) {
        if(detected_situation == 1) {
            prediction_active = 1;
            prediction_threshold = 1;
            prediction_time = 1600;
        } else if(detected_situation == 2) {
            prediction_active = 1;
            prediction_threshold = 1;
        } else {
            prediction_active = 0;
        }
