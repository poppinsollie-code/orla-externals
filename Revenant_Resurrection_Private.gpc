function DrawScreensaver() {
cls_oled(OLED_BLACK);
line_oled(4, 2, 123, 2, 2, OLED_WHITE);
line_oled(4, 50, 123, 50, 2, OLED_WHITE);
line_oled(4, 2, 4, 50, 2, OLED_WHITE);
line_oled(123, 2, 123, 50, 2, OLED_WHITE);
line_oled(8, 6, 119, 6, 1, OLED_WHITE);
line_oled(8, 46, 119, 46, 1, OLED_WHITE);
line_oled(8, 6, 8, 46, 1, OLED_WHITE);
line_oled(119, 6, 119, 46, 1, OLED_WHITE);
print(8, 54, OLED_FONT_SMALL, OLED_WHITE, STR_MENU[0]);
print(75, 54, OLED_FONT_SMALL, OLED_WHITE, STR_KILL[0]);
if(screensaver_phase == 0) {
DrawRevenantOwner();
if(letter_idx > 0) print(16, 52, OLED_FONT_SMALL, OLED_WHITE, LTR_E[0]);
if(letter_idx > 0) print(102, 52, OLED_FONT_SMALL, OLED_WHITE, LTR_T[0]);
if(letter_idx > 1) print(16, 36, OLED_FONT_SMALL, OLED_WHITE, LTR_V[0]);
if(letter_idx > 1) print(102, 36, OLED_FONT_SMALL, OLED_WHITE, LTR_N[0]);
if(letter_idx > 2) print(16, 20, OLED_FONT_SMALL, OLED_WHITE, LTR_E[0]);
if(letter_idx > 2) print(102, 20, OLED_FONT_SMALL, OLED_WHITE, LTR_A[0]);
if(letter_idx > 3) print(16, 4, OLED_FONT_SMALL, OLED_WHITE, LTR_R[0]);
if(letter_idx > 3) print(102, 4, OLED_FONT_SMALL, OLED_WHITE, LTR_N[0]);
if(letter_idx == 0) {
    print(16, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_E[0]);
    print(102, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_T[0]);
} else if(letter_idx == 1) {
    print(16, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_V[0]);
    print(102, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_N[0]);
} else if(letter_idx == 2) {
    print(16, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_E[0]);
    print(102, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_A[0]);
} else if(letter_idx == 3) {
    print(16, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_R[0]);
    print(102, letter_ypos, OLED_FONT_SMALL, OLED_WHITE, LTR_N[0]);
}
temp1 = 52 - (letter_idx * 16);
letter_ypos = letter_ypos + 2;
if(letter_ypos >= temp1) {
    letter_ypos = 0;
    letter_idx = letter_idx + 1;
}
if(letter_idx >= 4) {
    screensaver_phase = 1;
    }
}
else if(screensaver_phase == 1) {
DrawRevenantOwner();
print(16, 4, OLED_FONT_SMALL, OLED_WHITE, LTR_R[0]);
print(16, 20, OLED_FONT_SMALL, OLED_WHITE, LTR_E[0]);
print(16, 36, OLED_FONT_SMALL, OLED_WHITE, LTR_V[0]);
print(16, 52, OLED_FONT_SMALL, OLED_WHITE, LTR_E[0]);
print(102, 4, OLED_FONT_SMALL, OLED_WHITE, LTR_N[0]);
print(102, 20, OLED_FONT_SMALL, OLED_WHITE, LTR_A[0]);
print(102, 36, OLED_FONT_SMALL, OLED_WHITE, LTR_N[0]);
print(102, 52, OLED_FONT_SMALL, OLED_WHITE, LTR_T[0]);
}
}
function DrawKillscreen() {
if(killswitch) DrawRevenantOwner();
    cls_oled(OLED_BLACK);
line_oled(0, 4, 28, 4, 1, OLED_WHITE);
print(34, 0, OLED_FONT_SMALL, OLED_WHITE, STR_KSWITCH[0]);
line_oled(95, 4, 123, 4, 1, OLED_WHITE);
rect_oled(44, 12, 40, 42, 0, OLED_WHITE);
rect_oled(46, 14, 36, 38, 0, OLED_WHITE);
rect_oled(54, 18, 20, 30, 1, OLED_WHITE);
rect_oled(56, 20, 16, 26, 1, OLED_BLACK);
putc_oled(1, 79);
putc_oled(2, 78);
puts_oled(90, 18, OLED_FONT_SMALL, 2, OLED_WHITE);
putc_oled(1, 79);
putc_oled(2, 70);
putc_oled(3, 70);
puts_oled(88, 40, OLED_FONT_SMALL, 3, OLED_WHITE);
if(anim_frame < 4) {
lever_y = 20 + (anim_frame * 5);
} else {
lever_y = 35;
}
rect_oled(52, lever_y, 24, 12, 1, OLED_WHITE);
rect_oled(54, lever_y + 2, 20, 8, 1, OLED_BLACK);
line_oled(56, lever_y + 4, 72, lever_y + 4, 1, OLED_WHITE);
line_oled(56, lever_y + 6, 72, lever_y + 6, 1, OLED_WHITE);
line_oled(56, lever_y + 8, 72, lever_y + 8, 1, OLED_WHITE);
if(lever_y < 28) {
circle_oled(34, 24, 4, 1, OLED_WHITE);
} else {
circle_oled(34, 24, 4, 0, OLED_WHITE);
}
if(lever_y >= 28) {
circle_oled(34, 40, 4, 1, OLED_WHITE);
} else {
circle_oled(34, 40, 4, 0, OLED_WHITE);
}
if(anim_frame == 2||anim_frame == 6) {
spark_x = 78;
spark_y = 28;
line_oled(spark_x, spark_y, spark_x + 8, spark_y - 4, 1, OLED_WHITE);
line_oled(spark_x + 8, spark_y - 4, spark_x + 4, spark_y + 2, 1, OLED_WHITE);
line_oled(spark_x + 4, spark_y + 2, spark_x + 12, spark_y, 1, OLED_WHITE);
line_oled(20, 30, 14, 26, 1, OLED_WHITE);
line_oled(14, 26, 18, 34, 1, OLED_WHITE);
}
if(anim_frame == 3||anim_frame == 7) {
pixel_oled(80, 25, OLED_WHITE);
pixel_oled(85, 30, OLED_WHITE);
pixel_oled(82, 35, OLED_WHITE);
pixel_oled(18, 28, OLED_WHITE);
pixel_oled(22, 32, OLED_WHITE);
}
line_oled(5, 50, 122, 50, 1, OLED_WHITE);
if(lever_y >= 28) {
print(46, 52, OLED_FONT_SMALL, OLED_WHITE, STR_KILLED[0]);
} else {
print(37, 52, OLED_FONT_SMALL, OLED_WHITE, STR_DBLTAP[0]);
}
} 
